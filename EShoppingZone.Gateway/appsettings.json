{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/api/Profiles/{**remainder}"
        }
      },
      "auth-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/api/Auth/{**remainder}"
        }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/api/Products/{**remainder}"
        }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/api/carts/{**remainder}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/{**remainder}"
        }
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/api/wallet/{**remainder}"
        }
      },
      "review-route": {
        "ClusterId": "review-cluster",
        "Match": {
          "Path": "/api/reviews/{**remainder}"
        }
      },
      "notify-route": {
        "ClusterId": "notify-cluster",
        "Match": {
          "Path": "/api/notifications/{**remainder}"
        }
      },
      "profile-docs": { "ClusterId": "profile-cluster", "Match": { "Path": "/profile-docs/{**remainder}" }, "Transforms": [ { "PathRemovePrefix": "/profile-docs" }, { "PathPrefix": "/swagger" } ] },
      "product-docs": { "ClusterId": "product-cluster", "Match": { "Path": "/product-docs/{**remainder}" }, "Transforms": [ { "PathRemovePrefix": "/product-docs" }, { "PathPrefix": "/swagger" } ] },
      "cart-docs":    { "ClusterId": "cart-cluster",    "Match": { "Path": "/cart-docs/{**remainder}" },    "Transforms": [ { "PathRemovePrefix": "/cart-docs" },    { "PathPrefix": "/swagger" } ] },
      "order-docs":   { "ClusterId": "order-cluster",   "Match": { "Path": "/order-docs/{**remainder}" },   "Transforms": [ { "PathRemovePrefix": "/order-docs" },   { "PathPrefix": "/swagger" } ] },
      "wallet-docs":  { "ClusterId": "wallet-cluster",  "Match": { "Path": "/wallet-docs/{**remainder}" },  "Transforms": [ { "PathRemovePrefix": "/wallet-docs" },  { "PathPrefix": "/swagger" } ] },
      "review-docs":  { "ClusterId": "review-cluster",  "Match": { "Path": "/review-docs/{**remainder}" },  "Transforms": [ { "PathRemovePrefix": "/review-docs" },  { "PathPrefix": "/swagger" } ] },
      "notify-docs":  { "ClusterId": "notify-cluster",  "Match": { "Path": "/notify-docs/{**remainder}" },  "Transforms": [ { "PathRemovePrefix": "/notify-docs" },  { "PathPrefix": "/swagger" } ] }
    },

    "Clusters": {
      "profile-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "wallet-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "review-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "notify-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5007"
          }
        }
      }
    }
  }
}
